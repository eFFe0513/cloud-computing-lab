# The ownCloud version
OWNCLOUD_VERSION=latest

# The ownCloud domain (HTTPS gestito da nginx-proxy)
OWNCLOUD_DOMAIN=owncloud.filippobilardo.it

# The ownCloud trusted domains (separati da virgola)
OWNCLOUD_TRUSTED_DOMAINS=owncloud.filippobilardo.it,100.120.226.7,100.120.226.7:9090

# The admin username and password
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

